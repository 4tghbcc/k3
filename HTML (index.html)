<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Слайдер изображений</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="slider-container">
        <h1 class="slider-title">Галерея изображений</h1>
        
        <div class="slider-wrapper">
            <div class="slider">
                <img src="images/image1.jpg" alt="Изображение 1" class="slider-image active">
                <img src="images/image2.jpg" alt="Изображение 2" class="slider-image">
                <img src="images/image3.jpg" alt="Изображение 3" class="slider-image">
                <img src="images/image4.jpg" alt="Изображение 4" class="slider-image">
                <img src="images/image5.jpg" alt="Изображение 5" class="slider-image">
            </div>
            
            <button class="slider-button prev" aria-label="Предыдущее изображение">←</button>
            <button class="slider-button next" aria-label="Следующее изображение">→</button>
        </div>
        
        <div class="slider-counter">
            Изображение <span id="current-image">1</span> из <span id="total-images">5</span>
        </div>
        
        <div class="slider-dots">
            <!-- Точки будут добавлены через JavaScript -->
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
